# Zaprint Desktop - Environment Variables
# Copy this file to .env and fill in the values

# Supabase (public — safe for client-side / renderer)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_KEY=your-anon-key-here

# === SECRET KEYS — DO NOT prefix with VITE_ ===
# Keys without the VITE_ prefix are ONLY accessible in the Electron main process
# and are NEVER bundled into the renderer (client-side) JavaScript.

# Supabase Service Role Key — bypasses all RLS, keep strictly server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Razorpay credentials — used for payment processing in main process
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-secret-key-here
